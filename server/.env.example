# Othrys Server Configuration
# Copy to .env and fill in values

# Required
API_SECRET=change-me-generate-with-openssl-rand-hex-32
POSTGRES_PASSWORD=change-me

# Optional — only needed for LLM task splitting
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-your-key-here
LLM_MODEL=claude-sonnet-4-6

# Server
PORT=8080

# Domain (required for production HTTPS via Caddy)
DOMAIN=othrys.yourdomain.com
